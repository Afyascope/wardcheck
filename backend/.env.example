# ─── Required ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/wardcheck?schema=public"
JWT_SECRET="change-this-to-a-long-random-secret-at-least-32-chars"

# ─── Server ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS (comma-separated origins; ignored in development) ─
CORS_ORIGINS="https://wardcheck.example.com,https://www.wardcheck.example.com"

# ─── Report tuning ──────────────────────────────────────────
REPORT_DUPLICATE_WINDOW_DAYS=30
REPORT_RATE_LIMIT_HOURLY=5
REPORT_RATE_LIMIT_DAILY=20
REPORT_SUSPICIOUS_THRESHOLD=3
REPORT_PRIMARY_CONCERN_THRESHOLD=3
